{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities — required for the main window to access core/plugin commands",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "notification:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        {
          "url": "https://**"
        },
        {
          "url": "http://**"
        }
      ]
    }
  ]
}
